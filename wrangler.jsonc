{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "formzero-panaderia",
	"compatibility_date": "2025-04-04",
	"compatibility_flags": [
        "nodejs_compat"
    ],
	"main": "./workers/app.ts",
	"observability": {
		"enabled": true
	},
	"d1_databases": [
		{
			"binding": "DB",
			"database_name": "formzero-pedidos",
			"database_id": "6d97184f-5ff1-465f-9541-3f0d69e325b0",
		}
	]
}